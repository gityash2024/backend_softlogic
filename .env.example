# Server
NODE_ENV=development
PORT=3000
API_VERSION=v1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-admin-panel.vercel.app

# Database
DATABASE_URL=postgresql://postgres:password@localhost:54320/softlogic_whiteboard

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your_access_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_here_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Seed Admin
SEED_SUPER_ADMIN_EMAIL=admin@softlogicwhiteboard.com
SEED_SUPER_ADMIN_NAME=Softlogic Super Admin

# Google OAuth
# Required for Google sign-in token verification. This must match the
# Google server/web client ID used by the Flutter app.
GOOGLE_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Required for Windows desktop Google sign-in callback flow.
# Example: https://your-backend-domain.example.com/api/v1/auth/google/desktop/callback
GOOGLE_OAUTH_REDIRECT_URI=

# Email
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
BREVO_API_KEY=
BREVO_API_URL=https://api.brevo.com/v3/smtp/email
BREVO_FROM_EMAIL=
BREVO_FROM_NAME=
EMAIL_FROM=noreply@softlogicwhiteboard.com
EMAIL_FROM_NAME=Softlogic Whiteboard
DEV_FIXED_OTP_ENABLED=false
DEV_FIXED_OTP_CODE=1234
DEV_FIXED_OTP_ALLOWED_EMAILS=admin@softlogicwhiteboard.com
TESTING_RELAX_AUTH_LIMITS=false
IMPORT_CONVERSION_WORKER_URL=
IMPORT_CONVERSION_WORKER_TOKEN=
CONVERTAPI_TOKEN=
CONVERTAPI_BASE_URL=https://v2.convertapi.com

# Live sessions / RTC
LIVEKIT_URL=https://your-livekit-host.example.com
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=
PUBLIC_DOWNLOAD_PAGE_URL=https://softlogicwhiteboard.com/download
PUBLIC_APP_URL=https://softlogicwhiteboard.com
PUBLIC_BACKEND_URL=http://localhost:3000
PUBLIC_ADMIN_URL=https://adminpanelsoftlogic.vercel.app

# Search / external providers
SERPER_API_KEY=your_serper_api_key
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
GOOGLE_TRANSLATE_API_KEY=
YOUTUBE_API_KEY=your_youtube_data_api_key
DROPBOX_CLIENT_ID=your_dropbox_client_id
DROPBOX_CLIENT_SECRET=your_dropbox_client_secret
GOOGLE_DRIVE_CLIENT_ID=your_google_drive_client_id
GOOGLE_DRIVE_CLIENT_SECRET=your_google_drive_client_secret
GOOGLE_DRIVE_REDIRECT_URI=https://softlogicwhiteboard.com/oauth/google-drive/callback
ONEDRIVE_CLIENT_ID=your_onedrive_client_id
ONEDRIVE_CLIENT_SECRET=your_onedrive_client_secret
ONEDRIVE_REDIRECT_URI=https://softlogicwhiteboard.com/oauth/onedrive/callback

# Activation key encryption (32+ chars) — required in production.
# Used to encrypt the raw activation keys so super admin can reveal/email them later.
ACTIVATION_KEY_CIPHER_SECRET=change_me_to_a_32_char_or_longer_random_value

# Cron job authorization secret. The scheduled subscription sweep (Vercel cron) must send
# `Authorization: Bearer <CRON_SECRET>`. Generate a long random hex value in production.
CRON_SECRET=change_me_to_a_long_random_hex_value

# Cloudinary
CLOUDINARY_CLOUD_NAME=dssi3kihf
CLOUDINARY_API_KEY=318496972322612
CLOUDINARY_API_SECRET=WHnM-S3f9tGJAm11M7KnhqQKuck

# File Storage (MinIO for local dev)
STORAGE_TYPE=minio
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=whiteboard-files

# AWS S3 (production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET=
STORAGE_BUCKET=softlogic-live-assets
STORAGE_REGION=ap-south-1
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_PUBLIC_BASE_URL=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Profanity
PROFANITY_ENABLED=true

# Google Billing verification (optional, Super Admin AI module)
GOOGLE_BILLING_SYNC_ENABLED=false
GOOGLE_BILLING_PROJECT_ID=
GOOGLE_BILLING_DATASET_ID=
GOOGLE_BILLING_DETAILED_TABLE=
GOOGLE_BILLING_PRICING_TABLE=
GOOGLE_BILLING_MONTHLY_CAP_MICROS=50000000
GOOGLE_BILLING_SERVICE_ACCOUNT_PATH=
