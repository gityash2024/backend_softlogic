generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                   @id @default(uuid())
  email                 String                   @unique
  name                  String?
  avatar                String?
  googleId              String?                  @unique
  passwordHash          String?
  isEmailVerified       Boolean                  @default(false)
  role                  UserRole                 @default(STUDENT)
  status                UserStatus               @default(ACTIVE)
  timezone              String                   @default("UTC")
  language              String                   @default("en")
  invitedAt             DateTime                 @default(now())
  lastLoginAt           DateTime?
  invitedById           String?
  primaryOrganizationId String?
  archivedEmail         String?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  deletedAt             DateTime?

  invitedBy             User?                    @relation("UserInvitations", fields: [invitedById], references: [id], onDelete: SetNull)
  invitedUsers          User[]                   @relation("UserInvitations")
  primaryOrganization   Organization?            @relation("PrimaryOrganization", fields: [primaryOrganizationId], references: [id], onDelete: SetNull)
  sessions              Session[]
  otps                  Otp[]
  canvases              Canvas[]
  userSettings          UserSettings?
  memberships           OrganizationMembership[]
  exports               Export[]
  subscriptions         Subscription[]           @relation("SubscriptionOwner")
  subscriptionsCreated  Subscription[]           @relation("SubscriptionCreatedBy")
  auditLogs             AdminAuditLog[]          @relation("AuditActor")
  liveSessionsCreated   LiveSession[]            @relation("LiveSessionCreator")
  liveSessionsHosted    LiveSession[]            @relation("LiveSessionHost")
  liveSessionParticipants LiveSessionParticipant[]
  liveSessionInvitesSent LiveSessionInvite[]      @relation("LiveSessionInviteSender")
  liveSessionInvites     LiveSessionInvite[]      @relation("LiveSessionInviteUser")
  liveSessionMessages    LiveSessionMessage[]
  liveSessionRecordings  LiveSessionRecording[]
  liveSessionEvents      LiveSessionEvent[]
  oauthConnections       OAuthConnection[]
  lmsConnections         LmsConnection[]
  lmsSyncJobs            LmsSyncJob[]
  googleDesktopAuthAttempts GoogleDesktopAuthAttempt[]
  parentLinks            ParentStudentLink[]    @relation("ParentLinks")
  studentParentLinks     ParentStudentLink[]    @relation("StudentParentLinks")
  storageConnectionsConnected OrganizationStorageConnection[] @relation("StorageConnectionsConnectedBy")
  checkoutSessionsCreated CheckoutSession[]     @relation("CheckoutSessionsCreatedBy")
  paymentTransactionsRecorded PaymentTransaction[] @relation("PaymentTransactionsRecordedBy")
  hardwareKeysAssigned   HardwareActivationKey[] @relation("HardwareKeysAssignedUser")
  hardwareKeysCreated    HardwareActivationKey[] @relation("HardwareKeysCreatedBy")
  hardwareActivations    HardwareActivation[]   @relation("HardwareActivationsUser")
  hardwareResetsApproved HardwareActivation[]   @relation("HardwareActivationsResetApprovedBy")
  aiCreditAccounts       AiCreditAccount[]      @relation("AiCreditAccountsUser")
  aiCreditLedgerEntries  AiCreditLedgerEntry[]  @relation("AiCreditLedgerActor")
  termsAcceptances       TermsAcceptance[]      @relation("TermsAcceptancesUser")
  primaryAdminOrganizations Organization[]      @relation("OrganizationPrimaryAdmin")
  supportThreadsOpened    SupportThread[]        @relation("SupportThreadsOpened")
  supportThreadsResolved  SupportThread[]        @relation("SupportThreadsResolved")
  supportMessagesAuthored SupportMessage[]       @relation("SupportMessagesAuthored")
  supportThreadEventsActor SupportThreadEvent[]  @relation("SupportThreadEventsActor")

  @@map("users")
}

enum UserRole {
  STUDENT
  TEACHER
  PARENT
  CUSTOMER_ADMIN
  PARTNER_ADMIN
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  DISABLED
}

model Organization {
  id                 String                 @id @default(uuid())
  name               String
  slug               String                 @unique
  kind               OrganizationKind       @default(CUSTOMER)
  status             OrganizationStatus     @default(ACTIVE)
  brandingMode       BrandingMode           @default(SOFTLOGIC)
  studentLoginEnabled Boolean                @default(false)
  parentLoginEnabled  Boolean                @default(false)
  sessionOnlyJoinEnabled Boolean             @default(true)
  teacherOnlyMode    Boolean                @default(false)
  supportEmail       String?
  supportPhone       String?
  primaryAdminUserId String?
  archivedSlug       String?
  archivedSupportEmail String?
  storageProviders   OrganizationStorageProvider[] @default([])
  storageProvider    OrganizationStorageProvider?
  storageStatus      OrganizationStorageStatus @default(NOT_CONFIGURED)
  logoUrl            String?
  logoPublicId       String?
  brandName          String?
  brandPrimaryColor  String?
  brandAccentColor   String?
  settings           Json                   @default("{}")
  parentOrganizationId String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  deletedAt          DateTime?

  parentOrganization Organization?          @relation("OrganizationHierarchy", fields: [parentOrganizationId], references: [id], onDelete: SetNull)
  childOrganizations Organization[]         @relation("OrganizationHierarchy")
  primaryAdminUser   User?                  @relation("OrganizationPrimaryAdmin", fields: [primaryAdminUserId], references: [id], onDelete: SetNull)
  memberships        OrganizationMembership[]
  primaryUsers       User[]                 @relation("PrimaryOrganization")
  canvases           Canvas[]
  subscriptions      Subscription[]
  liveSessions       LiveSession[]
  parentStudentLinks ParentStudentLink[]
  storageConnections OrganizationStorageConnection[]
  aiCreditAccounts   AiCreditAccount[]
  hardwareActivationKeys HardwareActivationKey[]
  hardwareActivations HardwareActivation[]
  checkoutSessions   CheckoutSession[]
  paymentTransactions PaymentTransaction[]
  liveSessionGuestParticipants LiveSessionGuestParticipant[]
  termsAcceptances TermsAcceptance[]
  supportThreads SupportThread[]

  @@map("organizations")
  @@index([primaryAdminUserId])
  @@index([deletedAt])
}

enum OrganizationKind {
  INTERNAL
  PARTNER
  CUSTOMER
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
}

enum BrandingMode {
  SOFTLOGIC
  SOFTLOGIC_PARTNER
  WHITE_LABEL
  MULTI_BRAND
}

enum OrganizationStorageProvider {
  GOOGLE_DRIVE
  DROPBOX
  ONEDRIVE
}

enum OrganizationStorageStatus {
  NOT_CONFIGURED
  PENDING
  CONNECTED
  INVALID
}

model OrganizationMembership {
  id             String       @id @default(uuid())
  userId         String
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("organization_memberships")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  deviceInfo   Json?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model GoogleDesktopAuthAttempt {
  id            String                        @id @default(uuid())
  userId        String?
  state         String                        @unique
  status        GoogleDesktopAuthAttemptStatus @default(PENDING)
  errorMessage  String?
  sessionPayload Json?
  expiresAt     DateTime
  completedAt   DateTime?
  consumedAt    DateTime?
  createdAt     DateTime                      @default(now())
  updatedAt     DateTime                      @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, expiresAt])
  @@map("google_desktop_auth_attempts")
}

enum GoogleDesktopAuthAttemptStatus {
  PENDING
  COMPLETED
  FAILED
  EXPIRED
}

model Otp {
  id        String   @id @default(uuid())
  userId    String
  code      String
  type      OtpType
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otps")
}

enum OtpType {
  EMAIL_LOGIN
  EMAIL_VERIFY
  PASSWORD_RESET
}

model UserSettings {
  id              String   @id @default(uuid())
  userId          String   @unique
  theme           String   @default("light")
  language        String   @default("en")
  timezone        String   @default("UTC")
  autoTimezoneEnabled Boolean @default(false)
  performanceMode Boolean  @default(false)
  performanceLevel PerformanceLevel @default(HIGH)
  profanityFilter Boolean  @default(true)
  customProfanityWords Json?
  defaultPenSize  Float    @default(4.0)
  defaultPenColor String   @default("#000000")
  recentColors    Json?
  favoriteColors  Json?
  shortcuts       Json?
  notifications   Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model TranslationCache {
  id             String   @id @default(uuid())
  sourceLanguage String
  targetLanguage String
  sourceHash     String
  sourceText     String
  translatedText String
  provider       String   @default("google")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([sourceLanguage, targetLanguage, sourceHash])
  @@index([targetLanguage])
}

enum PerformanceLevel {
  LOW
  MEDIUM
  HIGH
}

model Canvas {
  id             String   @id @default(uuid())
  userId         String
  organizationId String?
  name           String
  description    String?
  metadata       Json?
  thumbnail      String?
  isPublic       Boolean  @default(false)
  shareToken     String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  slides       Slide[]
  exports      Export[]
  liveSessions LiveSession[]

  @@index([organizationId])
  @@map("canvases")
}

model Slide {
  id        String   @id @default(uuid())
  canvasId  String
  order     Int
  name      String?
  elements  Json     @default("[]")
  thumbnail String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  canvas Canvas @relation(fields: [canvasId], references: [id], onDelete: Cascade)

  @@map("slides")
}

model Export {
  id          String       @id @default(uuid())
  canvasId    String
  userId      String
  format      ExportFormat
  status      ExportStatus @default(PENDING)
  fileUrl     String?
  fileSize    Int?
  error       String?
  createdAt   DateTime     @default(now())
  completedAt DateTime?

  canvas Canvas @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("exports")
}

enum ExportFormat {
  PDF
  PNG
  JPG
  SVG
}

enum ExportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Subscription {
  id             String             @id @default(uuid())
  organizationId String?
  userId         String?
  createdById    String?
  planName       String
  status         SubscriptionStatus @default(ACTIVE)
  brandingMode   BrandingMode       @default(SOFTLOGIC)
  seatLimit      Int                @default(1)
  seatUsage      Int                @default(0)
  seatAlertTier        Int?
  expiryReminderTier   Int?
  startDate      DateTime
  endDate        DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user         User?         @relation("SubscriptionOwner", fields: [userId], references: [id], onDelete: SetNull)
  createdBy    User?         @relation("SubscriptionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  checkoutSessions CheckoutSession[]
  paymentTransactions PaymentTransaction[]
  hardwareActivationKeys HardwareActivationKey[]

  @@index([organizationId])
  @@index([userId])
  @@index([createdById])
  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELED
  TRIAL
  // Appended LAST on purpose: Postgres orders enums by declaration order and
  // findUserContextById sorts subscriptions by `status asc` with no status
  // filter, so keeping PENDING_APPROVAL last prevents a pending subscription
  // from shadowing a real ACTIVE one in the user's /me context.
  PENDING_APPROVAL
}

model ParentStudentLink {
  id             String   @id @default(uuid())
  parentUserId   String
  studentUserId  String
  organizationId String
  status         ParentStudentLinkStatus @default(ACTIVE)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  parentUser   User         @relation("ParentLinks", fields: [parentUserId], references: [id], onDelete: Cascade)
  studentUser  User         @relation("StudentParentLinks", fields: [studentUserId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([parentUserId, studentUserId, organizationId])
  @@index([organizationId])
  @@index([studentUserId])
  @@map("parent_student_links")
}

enum ParentStudentLinkStatus {
  ACTIVE
  DISABLED
}

model AdminAuditLog {
  id        String   @id @default(uuid())
  actorUserId String
  action    String
  targetType String
  targetId   String?
  summary   String?
  metadata  Json?
  createdAt DateTime @default(now())

  actorUser User @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([actorUserId])
  @@map("admin_audit_logs")
}

model OrganizationStorageConnection {
  id               String   @id @default(uuid())
  organizationId   String
  provider         OrganizationStorageProvider
  status           OrganizationStorageStatus @default(PENDING)
  encryptedTokens  String?
  externalAccountEmail String?
  rootFolderId     String?
  connectedById    String?
  validatedAt      DateTime?
  disconnectedAt   DateTime?
  lastError        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  connectedBy  User?        @relation("StorageConnectionsConnectedBy", fields: [connectedById], references: [id], onDelete: SetNull)

  @@unique([organizationId, provider])
  @@index([status])
  @@map("organization_storage_connections")
}

model PaymentProviderConfig {
  id          String          @id @default(uuid())
  provider    PaymentProvider @unique
  enabled     Boolean         @default(false)
  mode        PaymentProviderMode @default(TEST)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  checkoutSessions CheckoutSession[]
  paymentTransactions PaymentTransaction[]

  @@map("payment_provider_configs")
}

enum PaymentProvider {
  MANUAL
}

enum PaymentProviderMode {
  TEST
  LIVE
}

model CheckoutSession {
  id             String   @id @default(uuid())
  provider       PaymentProvider
  providerConfigId String?
  organizationId String?
  subscriptionId String?
  status         CheckoutSessionStatus @default(PENDING)
  checkoutUrl    String?
  amountMinor    Int
  currency       String @default("INR")
  metadata       Json   @default("{}")
  createdById    String
  expiresAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  providerConfig PaymentProviderConfig? @relation(fields: [providerConfigId], references: [id], onDelete: SetNull)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  createdBy      User @relation("CheckoutSessionsCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  paymentTransactions PaymentTransaction[]

  @@index([organizationId])
  @@index([subscriptionId])
  @@index([status])
  @@map("checkout_sessions")
}

enum CheckoutSessionStatus {
  PENDING
  COMPLETED
  EXPIRED
  CANCELED
}

model PaymentTransaction {
  id             String   @id @default(uuid())
  provider       PaymentProvider
  providerConfigId String?
  checkoutSessionId String?
  organizationId String?
  subscriptionId String?
  status         PaymentTransactionStatus @default(PENDING)
  amountMinor    Int
  currency       String @default("INR")
  externalPaymentId String?
  referenceNote  String?
  invoiceNumber  String?
  periodStart    DateTime?
  periodEnd      DateTime?
  metadata       Json @default("{}")
  recordedById   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  providerConfig PaymentProviderConfig? @relation(fields: [providerConfigId], references: [id], onDelete: SetNull)
  checkoutSession CheckoutSession? @relation(fields: [checkoutSessionId], references: [id], onDelete: SetNull)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  recordedBy     User? @relation("PaymentTransactionsRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([subscriptionId])
  @@index([status])
  @@map("payment_transactions")
}

enum PaymentTransactionStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  MANUAL_APPROVED
}

model HardwareActivationKey {
  id             String   @id @default(uuid())
  organizationId String
  subscriptionId String?
  activationKeyHash String @unique
  activationKeyEncrypted String?
  label          String?
  status         HardwareActivationKeyStatus @default(AVAILABLE)
  maxDevices     Int      @default(1)
  assignedUserId String?
  createdById    String
  boundActivationId String?
  expiresAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  assignedUser User? @relation("HardwareKeysAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  createdBy    User @relation("HardwareKeysCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  boundActivation HardwareActivation? @relation("BoundHardwareActivation", fields: [boundActivationId], references: [id], onDelete: SetNull)
  activations HardwareActivation[] @relation("HardwareKeyActivations")
  aiCreditAccounts AiCreditAccount[]

  @@index([organizationId])
  @@index([subscriptionId])
  @@index([status])
  @@map("hardware_activation_keys")
}

enum HardwareActivationKeyStatus {
  AVAILABLE
  BOUND
  DISABLED
  EXPIRED
}

model HardwareActivation {
  id             String   @id @default(uuid())
  activationKeyId String
  userId         String?
  organizationId String
  deviceFingerprintHash String
  deviceLabel    String?
  devicePlatform String?
  deviceModel    String?
  deviceOsVersion String?
  deviceMeta     Json     @default("{}")
  firstBoundAt   DateTime?
  lastVerifiedAt DateTime?
  status         HardwareActivationStatus @default(ACTIVE)
  resetRequestedAt DateTime?
  resetApprovedAt DateTime?
  resetApprovedById String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  activationKey HardwareActivationKey @relation("HardwareKeyActivations", fields: [activationKeyId], references: [id], onDelete: Cascade)
  boundKeys HardwareActivationKey[] @relation("BoundHardwareActivation")
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user      User? @relation("HardwareActivationsUser", fields: [userId], references: [id], onDelete: SetNull)
  resetApprovedBy User? @relation("HardwareActivationsResetApprovedBy", fields: [resetApprovedById], references: [id], onDelete: SetNull)

  @@unique([activationKeyId, deviceFingerprintHash])
  @@index([organizationId])
  @@index([userId])
  @@map("hardware_activations")
}

enum HardwareActivationStatus {
  ACTIVE
  RESET_REQUESTED
  RESET
  DISABLED
}

model AiCreditAccount {
  id             String   @id @default(uuid())
  scope          AiCreditScope
  organizationId String?
  userId         String?
  hardwareActivationKeyId String?
  balanceMinor   Int      @default(0)
  includedMinor  Int      @default(70000)
  currency       String   @default("INR")
  status         AiCreditAccountStatus @default(ACTIVE)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User? @relation("AiCreditAccountsUser", fields: [userId], references: [id], onDelete: Cascade)
  hardwareActivationKey HardwareActivationKey? @relation(fields: [hardwareActivationKeyId], references: [id], onDelete: SetNull)
  ledgerEntries AiCreditLedgerEntry[]

  @@index([organizationId])
  @@index([userId])
  @@index([scope])
  @@map("ai_credit_accounts")
}

enum AiCreditScope {
  ORGANIZATION
  USER
  HARDWARE
}

enum AiCreditAccountStatus {
  ACTIVE
  EXHAUSTED
  DISABLED
}

model AiCreditLedgerEntry {
  id             String   @id @default(uuid())
  accountId      String
  actorUserId    String?
  type           AiCreditLedgerType
  amountMinor    Int
  oldBalanceMinor Int
  newBalanceMinor Int
  reason         String?
  referenceNote  String?
  metadata       Json @default("{}")
  createdAt      DateTime @default(now())

  account   AiCreditAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  actorUser User? @relation("AiCreditLedgerActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([actorUserId])
  @@map("ai_credit_ledger_entries")
}

enum AiCreditLedgerType {
  INCLUDED
  USAGE
  MANUAL_EXTENSION
  ADJUSTMENT
}

model TermsAcceptance {
  id             String   @id @default(uuid())
  userId         String
  organizationId String?
  documentType   TermsDocumentType
  documentVersion String
  acceptedAt     DateTime @default(now())
  ipAddress      String?
  userAgent      String?
  metadata       Json @default("{}")

  user User @relation("TermsAcceptancesUser", fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([organizationId])
  @@map("terms_acceptances")
}

enum TermsDocumentType {
  TERMS
  PRIVACY
}

model LiveSession {
  id             String   @id @default(uuid())
  canvasId       String
  organizationId String?
  title          String?
  createdById    String
  hostUserId     String?
  status         LiveSessionStatus @default(SCHEDULED)
  joinCode       String?
  joinCodeHash   String?
  joinCodeExpiresAt DateTime?
  studentPermissions Json @default("{}")
  startedAt      DateTime?
  endedAt        DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  canvas       Canvas      @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdBy    User        @relation("LiveSessionCreator", fields: [createdById], references: [id], onDelete: Cascade)
  host         User?       @relation("LiveSessionHost", fields: [hostUserId], references: [id], onDelete: SetNull)
  participants LiveSessionParticipant[]
  invites      LiveSessionInvite[]
  messages     LiveSessionMessage[]
  mediaAssets  LiveSessionMediaAsset[]
  recordings   LiveSessionRecording[]
  events       LiveSessionEvent[]
  guestParticipants LiveSessionGuestParticipant[]

  @@index([canvasId])
  @@index([organizationId])
  @@index([status])
  @@map("live_sessions")
}

enum LiveSessionStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

model LiveSessionParticipant {
  id            String   @id @default(uuid())
  liveSessionId String
  userId        String
  role          LiveSessionParticipantRole @default(STUDENT)
  joinedAt      DateTime @default(now())
  leftAt        DateTime?

  liveSession LiveSession @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([liveSessionId, userId])
  @@index([userId])
  @@map("live_session_participants")
}

model LiveSessionGuestParticipant {
  id             String   @id @default(uuid())
  liveSessionId  String
  organizationId String?
  displayName    String?
  joinTokenHash   String @unique
  role            LiveSessionParticipantRole @default(STUDENT)
  expiresAt       DateTime
  joinedAt        DateTime?
  leftAt          DateTime?
  metadata        Json @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  liveSession  LiveSession @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([liveSessionId])
  @@index([organizationId])
  @@map("live_session_guest_participants")
}

enum LiveSessionParticipantRole {
  HOST
  TEACHER
  STUDENT
  OBSERVER
}

model LiveSessionInvite {
  id              String   @id @default(uuid())
  liveSessionId   String
  email           String
  invitedUserId   String?
  invitedById     String
  codeHash        String
  codeExpiresAt   DateTime
  usedAt          DateTime?
  downloadPageUrl String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  liveSession LiveSession @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  invitedUser User?       @relation("LiveSessionInviteUser", fields: [invitedUserId], references: [id], onDelete: SetNull)
  invitedBy   User        @relation("LiveSessionInviteSender", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([liveSessionId])
  @@index([email])
  @@index([codeExpiresAt])
  @@map("live_session_invites")
}

model LiveSessionMessage {
  id            String   @id @default(uuid())
  liveSessionId String
  senderUserId  String
  type          LiveSessionMessageType @default(TEXT)
  body          String?
  attachmentUrl String?
  attachmentName String?
  metadata      Json?
  createdAt     DateTime @default(now())

  liveSession LiveSession @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  sender      User        @relation(fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([liveSessionId, createdAt])
  @@map("live_session_messages")
}

enum LiveSessionMessageType {
  TEXT
  VOICE_NOTE
  MEDIA
  SYSTEM
}

model LiveSessionMediaAsset {
  id            String   @id @default(uuid())
  liveSessionId String
  uploadedById  String
  kind          LiveSessionMediaKind @default(FILE)
  fileName      String
  mimeType      String
  sizeBytes     Int
  storageKey    String
  publicUrl     String?
  metadata      Json?
  createdAt     DateTime @default(now())

  liveSession LiveSession @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)

  @@index([liveSessionId])
  @@map("live_session_media_assets")
}

enum LiveSessionMediaKind {
  FILE
  IMAGE
  VIDEO
  VOICE_NOTE
  IMPORT
}

model LiveSessionRecording {
  id            String   @id @default(uuid())
  liveSessionId String
  createdById   String
  status        LiveSessionRecordingStatus @default(PROCESSING)
  storageKey    String?
  publicUrl     String?
  durationSeconds Int?
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  liveSession LiveSession @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  createdBy   User        @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([liveSessionId])
  @@map("live_session_recordings")
}

enum LiveSessionRecordingStatus {
  PROCESSING
  READY
  FAILED
}

model LiveSessionEvent {
  id            String   @id @default(uuid())
  liveSessionId String
  actorUserId   String?
  type          String
  payload       Json?
  createdAt     DateTime @default(now())

  liveSession LiveSession @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  actor       User?       @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([liveSessionId, createdAt])
  @@map("live_session_events")
}

model OAuthConnection {
  id              String   @id @default(uuid())
  userId          String
  provider        OAuthProvider
  encryptedTokens String
  scopes          String?
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("oauth_connections")
}

enum OAuthProvider {
  GOOGLE
  DROPBOX
  GOOGLE_DRIVE
  LMS
}

model LmsConnection {
  id              String   @id @default(uuid())
  userId          String
  provider        String
  baseUrl         String?
  encryptedConfig String?
  status          String   @default("DISCONNECTED")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  syncJobs LmsSyncJob[]

  @@index([userId])
  @@map("lms_connections")
}

model LmsSyncJob {
  id              String   @id @default(uuid())
  userId          String
  connectionId    String?
  liveSessionId   String?
  status          String   @default("PENDING")
  direction       String   @default("EXPORT")
  payload         Json?
  errorMessage    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection LmsConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@map("lms_sync_jobs")
}

model FeedbackThread {
  id                 String               @id @default(uuid())
  resourceType       String
  resourceId         String
  anchor             Json?
  status             FeedbackThreadStatus @default(OPEN)
  authorClientId     String
  authorName         String
  authorEmail        String
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  resolvedAt         DateTime?
  resolvedByClientId String?
  resolvedByName     String?

  comments FeedbackComment[]

  @@index([resourceType, resourceId])
  @@index([status])
  @@map("feedback_threads")
}

model FeedbackComment {
  id             String    @id @default(uuid())
  threadId       String
  authorClientId String
  authorName     String
  authorEmail    String
  body           String
  editedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  thread FeedbackThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@map("feedback_comments")
}

enum FeedbackThreadStatus {
  OPEN
  RESOLVED
}

model SupportThread {
  id               String              @id @default(uuid())
  organizationId   String
  openedByUserId   String
  category         SupportCategory
  subject          String
  status           SupportThreadStatus @default(OPEN)
  priority         SupportPriority     @default(NORMAL)
  requestedAction  Json?
  resolvedByUserId String?
  resolvedAt       DateTime?
  closedAt         DateTime?
  lastActivityAt   DateTime            @default(now())
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  openedBy     User                @relation("SupportThreadsOpened", fields: [openedByUserId], references: [id], onDelete: Cascade)
  resolvedBy   User?               @relation("SupportThreadsResolved", fields: [resolvedByUserId], references: [id], onDelete: SetNull)
  messages     SupportMessage[]
  events       SupportThreadEvent[]

  @@index([organizationId, status])
  @@index([status, lastActivityAt])
  @@map("support_threads")
}

model SupportMessage {
  id           String    @id @default(uuid())
  threadId     String
  authorUserId String
  body         String
  editedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  thread SupportThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author User          @relation("SupportMessagesAuthored", fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@map("support_messages")
}

model SupportThreadEvent {
  id          String           @id @default(uuid())
  threadId    String
  actorUserId String
  type        SupportEventType
  payload     Json             @default("{}")
  createdAt   DateTime         @default(now())

  thread SupportThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  actor  User          @relation("SupportThreadEventsActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@map("support_thread_events")
}

enum SupportCategory {
  REQUEST_SEATS
  EXTEND_SUBSCRIPTION
  RESET_DEVICE
  BILLING
  ACTIVATION_ISSUE
  TECHNICAL
  USER_MANAGEMENT
  GENERAL
}

enum SupportThreadStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum SupportEventType {
  STATUS_CHANGE
  ACTION_APPLIED
  PRIORITY_CHANGE
  REPLIED
}
