generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                   @id @default(uuid())
  email                 String                   @unique
  name                  String?
  avatar                String?
  googleId              String?                  @unique
  isEmailVerified       Boolean                  @default(false)
  role                  UserRole                 @default(STUDENT)
  status                UserStatus               @default(ACTIVE)
  timezone              String                   @default("UTC")
  language              String                   @default("en")
  invitedAt             DateTime                 @default(now())
  lastLoginAt           DateTime?
  invitedById           String?
  primaryOrganizationId String?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  deletedAt             DateTime?

  invitedBy             User?                    @relation("UserInvitations", fields: [invitedById], references: [id], onDelete: SetNull)
  invitedUsers          User[]                   @relation("UserInvitations")
  primaryOrganization   Organization?            @relation("PrimaryOrganization", fields: [primaryOrganizationId], references: [id], onDelete: SetNull)
  sessions              Session[]
  otps                  Otp[]
  canvases              Canvas[]
  userSettings          UserSettings?
  memberships           OrganizationMembership[]
  exports               Export[]
  subscriptions         Subscription[]
  auditLogs             AdminAuditLog[]          @relation("AuditActor")
  liveSessionsCreated   LiveSession[]            @relation("LiveSessionCreator")
  liveSessionParticipants LiveSessionParticipant[]
  googleDesktopAuthAttempts GoogleDesktopAuthAttempt[]

  @@map("users")
}

enum UserRole {
  STUDENT
  TEACHER
  CUSTOMER_ADMIN
  PARTNER_ADMIN
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  DISABLED
}

model Organization {
  id                 String                 @id @default(uuid())
  name               String
  slug               String                 @unique
  kind               OrganizationKind       @default(CUSTOMER)
  status             OrganizationStatus     @default(ACTIVE)
  parentOrganizationId String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  parentOrganization Organization?          @relation("OrganizationHierarchy", fields: [parentOrganizationId], references: [id], onDelete: SetNull)
  childOrganizations Organization[]         @relation("OrganizationHierarchy")
  memberships        OrganizationMembership[]
  primaryUsers       User[]                 @relation("PrimaryOrganization")
  canvases           Canvas[]
  subscriptions      Subscription[]
  liveSessions       LiveSession[]

  @@map("organizations")
}

enum OrganizationKind {
  INTERNAL
  PARTNER
  CUSTOMER
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
}

model OrganizationMembership {
  id             String       @id @default(uuid())
  userId         String
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("organization_memberships")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  deviceInfo   Json?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model GoogleDesktopAuthAttempt {
  id            String                        @id @default(uuid())
  userId        String?
  state         String                        @unique
  status        GoogleDesktopAuthAttemptStatus @default(PENDING)
  errorMessage  String?
  sessionPayload Json?
  expiresAt     DateTime
  completedAt   DateTime?
  consumedAt    DateTime?
  createdAt     DateTime                      @default(now())
  updatedAt     DateTime                      @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, expiresAt])
  @@map("google_desktop_auth_attempts")
}

enum GoogleDesktopAuthAttemptStatus {
  PENDING
  COMPLETED
  FAILED
  EXPIRED
}

model Otp {
  id        String   @id @default(uuid())
  userId    String
  code      String
  type      OtpType
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otps")
}

enum OtpType {
  EMAIL_LOGIN
  EMAIL_VERIFY
  PASSWORD_RESET
}

model UserSettings {
  id              String   @id @default(uuid())
  userId          String   @unique
  theme           String   @default("light")
  language        String   @default("en")
  timezone        String   @default("UTC")
  autoTimezoneEnabled Boolean @default(false)
  performanceMode Boolean  @default(false)
  performanceLevel PerformanceLevel @default(HIGH)
  profanityFilter Boolean  @default(true)
  customProfanityWords Json?
  defaultPenSize  Float    @default(4.0)
  defaultPenColor String   @default("#000000")
  recentColors    Json?
  favoriteColors  Json?
  shortcuts       Json?
  notifications   Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

enum PerformanceLevel {
  LOW
  MEDIUM
  HIGH
}

model Canvas {
  id             String   @id @default(uuid())
  userId         String
  organizationId String?
  name           String
  description    String?
  metadata       Json?
  thumbnail      String?
  isPublic       Boolean  @default(false)
  shareToken     String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  slides       Slide[]
  exports      Export[]
  liveSessions LiveSession[]

  @@index([organizationId])
  @@map("canvases")
}

model Slide {
  id        String   @id @default(uuid())
  canvasId  String
  order     Int
  name      String?
  elements  Json     @default("[]")
  thumbnail String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  canvas Canvas @relation(fields: [canvasId], references: [id], onDelete: Cascade)

  @@map("slides")
}

model Export {
  id          String       @id @default(uuid())
  canvasId    String
  userId      String
  format      ExportFormat
  status      ExportStatus @default(PENDING)
  fileUrl     String?
  fileSize    Int?
  error       String?
  createdAt   DateTime     @default(now())
  completedAt DateTime?

  canvas Canvas @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("exports")
}

enum ExportFormat {
  PDF
  PNG
  JPG
  SVG
}

enum ExportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Subscription {
  id             String             @id @default(uuid())
  organizationId String?
  userId         String?
  planName       String
  status         SubscriptionStatus @default(ACTIVE)
  seatLimit      Int                @default(1)
  seatUsage      Int                @default(0)
  startDate      DateTime
  endDate        DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELED
  TRIAL
}

model AdminAuditLog {
  id        String   @id @default(uuid())
  actorUserId String
  action    String
  targetType String
  targetId   String?
  summary   String?
  metadata  Json?
  createdAt DateTime @default(now())

  actorUser User @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([actorUserId])
  @@map("admin_audit_logs")
}

model LiveSession {
  id             String   @id @default(uuid())
  canvasId       String
  organizationId String?
  title          String?
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  canvas       Canvas      @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdBy    User        @relation("LiveSessionCreator", fields: [createdById], references: [id], onDelete: Cascade)
  participants LiveSessionParticipant[]

  @@index([canvasId])
  @@map("live_sessions")
}

model LiveSessionParticipant {
  id            String   @id @default(uuid())
  liveSessionId String
  userId        String
  joinedAt      DateTime @default(now())
  leftAt        DateTime?

  liveSession LiveSession @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([liveSessionId, userId])
  @@index([userId])
  @@map("live_session_participants")
}
