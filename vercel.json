{
  "version": 2,
  "installCommand": "npm install --include=dev && npx prisma generate",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "includeFiles": "{prisma/**,dist/**,node_modules/.prisma/client/**}",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ]
}
