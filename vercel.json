{
  "version": 2,
  "installCommand": "npm install --include=dev && npx prisma generate",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "includeFiles": "{prisma/**,dist/**,node_modules/.prisma/client/**}",
      "memory": 1024,
      "maxDuration": 300
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ],
  "crons": [
    {
      "path": "/api/v1/admin/jobs/subscription-sweep",
      "schedule": "0 6 * * *"
    }
  ]
}
